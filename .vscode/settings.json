{
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "javascript.suggestionActions.enabled": true,
  "typescript.suggestionActions.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ]
}
